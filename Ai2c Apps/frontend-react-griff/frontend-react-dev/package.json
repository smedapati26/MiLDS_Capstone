{
  "name": "griffin-ai",
  "description": "Griffin.AI Application",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "preview": "vite preview --open",
    "prebuild": "rm -rf dist",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "build:test": "tsc -b && vite build --mode test",
    "build:prod": "tsc -b && vite build --mode production",
    "test": "vitest --typecheck --no-cache --mode development --pool=forks",
    "test:watch": "vitest --typecheck --watch --mode development --pool=forks",
    "test:coverage": "vitest --typecheck --coverage --mode development --pool=forks",
    "coverage:gitlab": "vitest --typecheck --coverage --reporter junit --reporter verbose --outputFile junit-report.xml --mode development --pool=forks --testTimeout=40000 --maxWorkers=3",
    "coverage": "vitest run --coverage --mode development --pool=forks",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\" --config ./.prettierrc.json",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "license": "ISC",
  "devDependencies": {
    "@fetch-mock/vitest": "0.2.7",
    "@hookform/devtools": "4.3.1",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-themes": "7.6.20",
    "@storybook/cli": "9.1.3",
    "@storybook/manager-api": "7.6.20",
    "@storybook/preview-api": "7.6.20",
    "@storybook/react": "9.1.3",
    "@storybook/react-vite": "9.1.3",
    "@storybook/testing-library": "0.2.1",
    "@storybook/types": "7.6.20",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.4.2",
    "@testing-library/react": "15.0.0",
    "@testing-library/react-hooks": "8.0.1",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.25",
    "@types/plotly.js": "2.35.2",
    "@types/react": "18.2.56",
    "@types/react-dom": "18.2.19",
