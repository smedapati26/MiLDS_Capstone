{
  "name": "amap",
  "description": "Aviation-Maintainer Analytics Platform",
  "version": "0.0.1",
  "type": "module",
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "scripts": {
    "dev": "vite --open",
    "preview": "vite preview --open",
    "prebuild": "rm -rf dist",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "build:test": "tsc -b && vite build --mode test",
    "build:prod": "tsc -b && vite build --mode production",
    "test": "vitest --typecheck",
    "test:coverage": "vitest --typecheck --coverage",
    "coverage:gitlab": "vitest --typecheck --coverage --reporter junit --reporter verbose --outputFile junit-report.xml",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\" --config ./.prettierrc.json",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "license": "ISC",
  "devDependencies": {
    "@hookform/devtools": "^4.3.1",
    "@mui/x-charts": "^7.29.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^7.6.20",
    "@storybook/cli": "^9.1.3",
    "@storybook/manager-api": "^7.6.20",
    "@storybook/preview-api": "^7.6.20",
    "@storybook/react": "^9.1.3",
    "@storybook/react-vite": "^9.1.3",
    "@storybook/types": "^7.6.20",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.25",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/react-plotly.js": "^2.6.3",
    "@types/redux-logger": "^3.0.13",
    "@types/redux-mock-store": "^1.5.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.2.3",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-refresh": "0.4.18",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-sonarjs": "3.0.1",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jsdom": "24.1.3",
    "jspdf": "3.0.1",
    "lint-staged": "15.4.3",
    "prettier": "3.4.2",
    "redux-logger": "3.0.6",
    "redux-mock-store": "1.5.5",
    "rimraf": "^5.0.7",
    "storybook": "^10.1.4",
    "typescript": "5.8.2",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.1.1",
    "vite-plugin-pwa": "0.21.1",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.0.17",
    "xlsx": "0.18.5"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fontsource/roboto": "^5.0.8",
    "@hookform/resolvers": "^3.9.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/styled-engine-sc": "^6.0.0-alpha.18",
    "@mui/x-data-grid": "^6.19.5",
    "@mui/x-date-pickers": "^7.22.3",
    "@mui/x-date-pickers-pro": "^7.1.1",
    "@mui/x-tree-view": "^7.13.0",
    "@reduxjs/toolkit": "^2.5.1",
    "@storybook/testing-library": "^0.2.1",
    "@types/react-router-dom": "^5.3.3",
    "dayjs": "1.11.13",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "jszip": "3.10.1",
    "jwt-decode": "^4.0.0",
    "msw": "2.7.0",
    "plotly.js": "2.35.3",
    "plotly.js-dist": "2.35.3",
    "plotly.js-dist-min": "2.35.3",
    "react": "18.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "18.3.1",
    "react-draggable": "^4.4.6",
    "react-hook-form": "7.54.2",
    "react-plotly.js": "2.6.0",
    "react-redux": "9.2.0",
    "react-router-dom": "6.29.0",
    "styled-components": "^6.1.12",
    "zod": "3.24.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
      "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\" --config ./.prettierrc.json"
    ]
  }
}
